@model PrinterMonitor.Models.Printer

<h1>Nova Impressora</h1>
<form asp-action="Create" method="post">
    <div class="mb-3">
        <label>Setor</label>
        <input asp-for="Setor" class="form-control"/>
    </div>
    <div class="mb-3">
        <label>Nome</label>
        <input asp-for="Nome" class="form-control"/>
    </div>
    <div class="mb-3">
        <label>IP</label>
        <input asp-for="Ip" class="form-control"/>
    </div>
    <div class="mb-3">
        <label>Modelo</label>
        <input asp-for="Modelo" class="form-control"/>
    </div>

    <button class="btn btn-success">
        Salvar
    </button>
</form>