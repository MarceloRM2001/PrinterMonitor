@model PrinterMonitor.Models.Printer

<h1>Editar Impressora</h1>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label>Setor</label>
        <input asp-for="Setor" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Nome</label>
        <input asp-for="Nome" class="form-control" />
    </div>
    <div class="mb-3">
        <label>IP</label>
        <input asp-for="Ip" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Modelo</label>
        <input asp-for="Modelo" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Serial Number</label>
        <input asp-for="SerialNumer" class="form-control" />
    </div>

    <button class="btn btn-success">
        Salvar
    </button>
</form>